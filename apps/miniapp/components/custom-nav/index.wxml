<view class="custom-nav-container" style="height: {{navBarHeight}}px; background: {{background}};">
  <view class="nav-content" style="top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px;">
    
    <view class="nav-back" bindtap="goBack" wx:if="{{back}}">
      <block wx:if="{{isFirstPage}}">
        <image class="home-icon" src="data:image/svg+xml;base64," />
      </block>
      <block wx:else>
        <text class="back-icon">‹</text>
        <text class="back-text">返回</text>
      </block>
    </view>
    
    <view class="nav-title" style="line-height: {{menuButtonHeight}}px;">
      {{title}}
    </view>

  </view>
</view>
<view class="nav-placeholder" wx:if="{{placeholder}}" style="height: {{navBarHeight}}px;"></view>
