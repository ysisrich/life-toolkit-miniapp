.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(5px);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}

.modal-backdrop.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 85vh; /* 弹窗高度 */
  background: #1c1c1e;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  /* 初始采用 CSS transition，后续由 WXS 接管 */
  transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
}

.modal-wrapper.show {
  transform: translateY(0);
}

.modal-handle {
  width: 100%;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.handle-bar {
  width: 80rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 5rpx;
}

.modal-content {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
