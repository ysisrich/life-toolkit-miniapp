.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 动态背景层 */
.bg-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
  background: #000000;
}

.bg-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.6;
  animation: blob-float 15s infinite alternate ease-in-out;
}

.blob-1 {
  top: -10%;
  left: -20%;
  width: 600rpx;
  height: 600rpx;
  background: rgba(94, 92, 230, 0.35); /* 优雅紫 */
  animation-delay: 0s;
}

.blob-2 {
  top: 40%;
  right: -20%;
  width: 700rpx;
  height: 700rpx;
  background: rgba(10, 132, 255, 0.25); /* 科技蓝 */
  animation-duration: 22s;
  animation-delay: -5s;
}

.blob-3 {
  bottom: -10%;
  left: 10%;
  width: 500rpx;
  height: 500rpx;
  background: rgba(255, 159, 10, 0.15); /* 温暖橙 */
  animation-duration: 18s;
  animation-delay: -10s;
}

@keyframes blob-float {
  0% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(40rpx, -60rpx) scale(1.1); }
  66% { transform: translate(-30rpx, 40rpx) scale(0.9); }
  100% { transform: translate(0, 0) scale(1); }
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  display: flex;
  align-items: center;
  padding-left: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: var(--text-primary);
}

.header {
  padding: 80rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.greeting-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.greeting {
  display: inline-block;
  font-size: 68rpx;
  font-weight: 800;
  background: linear-gradient(-60deg, #a0a0a0 30%, #ffffff 50%, #a0a0a0 70%);
  background-size: 300% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: shimmer 3s linear infinite;
  text-align: center;
  letter-spacing: 4rpx;
}

@keyframes shimmer {
  to {
    background-position: 300% center;
  }
}


.subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 20rpx;
}

.date-text {
  display: inline-block;
  font-size: 24rpx;
  color: var(--text-secondary, #8E8E93);
  margin-top: 24rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  letter-spacing: 2rpx;
}

/* 一行三个的网格布局 */
.grid-wrapper {
  position: relative;
  z-index: 1;
  padding: 0 40rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 60rpx 40rpx; /* 上下间距 60，左右间距 40 */
  padding-bottom: 100rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  /* GSAP 会通过 style 覆盖这里的初始值，但也可以写个防闪烁默认值 */
  opacity: 0; 
}

.grid-item:active .icon-box {
  transform: scale(0.92);
  filter: brightness(0.8);
}

.icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx; /* iOS 风格的圆角 */
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4), inset 0 0 2px rgba(255, 255, 255, 0.3);
  transition: transform 0.2s ease, filter 0.2s ease;
}

.icon-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.8;
  z-index: 1;
}

.tool-icon {
  width: 70rpx;
  height: 70rpx;
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));
}

.tool-name {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  text-align: center;
  /* 允许文字换行但最多两行 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.nav-settings {
  position: absolute;
  right: 40rpx;
  top: 90rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
}

