.container {
  min-height: 100vh;
  background-color: #000;
  color: #fff;
  box-sizing: border-box;
}

.content {
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 20rpx;
  margin-top: 40rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-btn {
  color: #0a84ff;
  font-weight: 500;
  font-size: 28rpx;
}

.glass-panel {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  backdrop-filter: blur(20px);
}

.active-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.empty-active {
  text-align: center;
  color: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
  padding: 40rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.bg-green {
  background: rgba(48, 209, 88, 0.15);
  color: #30d158;
  border: 1px solid rgba(48, 209, 88, 0.3);
}

.card-info {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.config-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.config-item {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s ease;
  border: 1px solid rgba(255, 255, 255, 0.04);
}

.config-item.selected {
  border: 1px solid rgba(48, 209, 88, 0.4);
  background: rgba(48, 209, 88, 0.03);
}

.item-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
}

.item-url {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.item-model {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.item-actions {
  display: flex;
  gap: 24rpx;
  margin-left: 20rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
}

.btn-svg {
  width: 28rpx;
  height: 28rpx;
}

/* 弹窗表单样式 */
.form-container {
  padding: 30rpx;
  color: #fff;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
  position: relative;
}

.label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 12rpx;
  display: block;
}

.input {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #fff;
}

.textarea {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  height: 120rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 50rpx;
}

.btn {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
}

.save-btn {
  background: #30d158;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(48, 209, 88, 0.35);
}

/* 输入框带操作按钮布局 */
.input-with-action {
  position: relative;
  display: flex;
  align-items: center;
}

.input-with-action .input {
  flex: 1;
  padding-right: 90rpx;
}

.input-with-action .action-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.input-with-action .action-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.8;
  transition: transform 0.3s ease;
}

.input-with-action .action-icon.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 下拉框样式 */
.dropdown-list {
  position: absolute;
  left: 0;
  right: 0;
  max-height: 350rpx;
  z-index: 100;
  margin-top: 8rpx;
  background: rgba(30, 30, 30, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.5);
}

.dropdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: rgba(255, 255, 255, 0.1);
}

.option-name {
  flex: 1;
  word-break: break-all;
}
