.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background: radial-gradient(circle at 50% 0%, #1a1a2e 0%, #000000 100%);
}

.content {
  padding: 40rpx;
}

.header {
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  letter-spacing: -1rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.form-group {
  border-radius: 32rpx;
  padding: 10rpx 40rpx;
  margin-bottom: 60rpx;
}

.input-item {
  display: flex;
  flex-direction: column;
  padding: 30rpx 0;
}

.switch-item {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.switch-item .label {
  margin-bottom: 0;
}

.label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.input {
  font-size: 32rpx;
  color: var(--text-primary);
  height: 60rpx;
}

.input-placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.divider {
  height: 1rpx;
  background: var(--card-border);
}

.action-group {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.btn {
  width: 100%;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn::after {
  display: none;
}

.btn-primary {
  background: #FFF;
  color: #000;
}

.btn-primary:active {
  background: rgba(255, 255, 255, 0.8);
  transform: scale(0.98);
}

.btn-secondary {
  background: var(--card-bg);
  color: var(--text-primary);
  border: 1rpx solid var(--card-border);
}

.btn-secondary:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

.help-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: center;
}

/* Nav back specific */
.nav-back {
  position: absolute;
  left: 30rpx;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--text-primary);
  font-size: 32rpx;
  z-index: 10;
}

.back-icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid var(--text-primary);
  border-bottom: 4rpx solid var(--text-primary);
  transform: rotate(45deg);
}
