.container {
  min-height: 100vh;
  position: relative;
  background-color: #000;
  display: flex;
  flex-direction: column;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.glass-panel {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20px);
}

.calendar-panel {
  width: 95%;
  padding: 30rpx;
  border-radius: 40rpx;
  animation: slideUpFade 0.6s ease-out forwards;
}

@keyframes slideUpFade {
  0% { transform: translateY(40rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 20rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.month-btn {
  padding: 10rpx 20rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

.month-btn:active {
  color: #fff;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 20rpx;
}

.weekday {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.weekday.weekend {
  color: rgba(255, 255, 255, 0.6);
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.calendar-cell {
  position: relative;
  min-height: 110rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 15rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid transparent;
}

.calendar-cell.empty {
  background: transparent;
  border: none;
}

.day-num {
  font-size: 28rpx;
  color: #fff;
  z-index: 2;
}

.calendar-cell.is-weekend .day-num {
  color: rgba(255, 255, 255, 0.5);
}

.record-dot {
  position: absolute;
  bottom: 8rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #30d158;
  box-shadow: 0 0 8px #30d158;
}

.calendar-cell.is-record {
  background: rgba(48, 209, 88, 0.1);
  border: 1px solid rgba(48, 209, 88, 0.3);
}

.badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  font-size: 16rpx;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
  font-weight: bold;
  z-index: 3;
}

.badge-holiday {
  background: #ff453a;
  color: #fff;
}

.badge-workday {
  background: #8e8e93;
  color: #fff;
}

.holiday-name {
  font-size: 18rpx;
  color: #ff453a;
  margin-top: auto;
  margin-bottom: 8rpx;
  text-align: center;
  line-height: 1.2;
}

.leave-text {
  position: absolute;
  bottom: 8rpx;
  font-size: 20rpx;
  color: #ff9f0a;
}

.calendar-cell.is-leave {
  background: rgba(255, 159, 10, 0.1);
  border: 1px solid rgba(255, 159, 10, 0.3);
}

.stats-summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  background: rgba(0,0,0,0.2);
  border-radius: 20rpx;
}

.stat-item {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #30d158;
}

.leave-num {
  color: #ff9f0a;
}
